{% extends 'base.html.twig' %}

{% block title %}Modifier{% endblock %}

{% block main %}
            <header>
               <div id="current-user"></div>
               <div id="title-page">
                  <h1>{{ project.name }}</h1>
               </div>
            </header>
            <div id="content">
               {{ form_start(form) }}
                  {{ form_row(form.name) }}
                  {{ form_row(form.users) }}
                  <br>
                  <button class="button button-submit">Modifier</button>
               {{ form_end(form) }}
            </div>
{% endblock %}