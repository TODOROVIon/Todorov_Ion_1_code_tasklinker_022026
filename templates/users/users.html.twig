{% extends 'base.html.twig' %}

{% block title %}Liste des employés{% endblock %}

{% block main %}
    <header>
        <div id="current-user"></div>
            <div id="title-page">
                <h1>Équipe</h1>
            </div>
    </header>
        <div id="content">
               <table id="team-container">
                  <thead>
                     <tr>
                        <th>Prénom, Nom</th>
                        <th>Statut</th>
                        <th>Actions</th>
                     </tr>
                  </thead>
                  <tbody>
                        {% for user in users %}
                     <tr>
                        <td>
                           <div class="employee-infos">
                              <div class="employee-avatar">
                                 ND
                              </div>
                              <div class="employee-coords">
                                 <strong>{{ user.firstName }} {{ user.lastName }}</strong>
                                 <span>{{ user.email }}</span>
                              </div>
                           </div>
                        </td>
                        <td>CDI</td>
                        <td>
                           <a class="button button-edit-team" href="#">
                           Éditer
                           </a>
                           <a class="delete-team" href="#">
                           Supprimer
                           </a>
                        </td>
                     </tr>
                     {% endfor %}              
                  </tbody>
               </table>
            </div>
    {% endblock %}